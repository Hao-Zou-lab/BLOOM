library(Seurat)
library(pls)
library(MASS)
library(ggplot2)
library(readxl)
library(tcltk)
library(STutility)
library(wrMisc)
library(scSTAR2)
library(circlize)
library(monocle)
library(dplyr)
mesophyll_cells <- readRDS("./mesophyll_cells_TL0.rds")
setwd("D:/projects/Temporary tasks/tobacco")
data_bulk = read.table("./all.count.txt", sep = "\t", header = T)
geneList_bulk = rownames(data_bulk)
# 提取数据矩阵并转换为数值型矩阵
data_matrix_bulk <- as.matrix(data_bulk)
data_matrix_bulk <- matrix(as.numeric(data_matrix_bulk), nrow = nrow(data_matrix_bulk))
# 设置行名和列名
rownames(data_matrix_bulk) <- geneList_bulk
colnames(data_matrix_bulk) <- colnames(data_bulk)
data_matrix_bulk <- data_matrix_bulk[!is.na(rownames(data_matrix_bulk)), ]
# 对数据进行log2 转换
data_matrix_bulk <- log2(data_matrix_bulk + 1)
# 设置位置向量
location <- c(rep('TL0', 3), rep('TL1', 3))
############# scSTAR2
data_matrix_sc <- as.matrix(mesophyll_cells@assays$RNA@counts)
geneList_sc = rownames(data_matrix_sc)
rownames(data_matrix_sc) <- geneList_sc
colnames(data_matrix_sc) <- colnames(mesophyll_cells)
# 找到 bulk 数据和单细胞数据中的共同基因
geneList <- intersect(geneList_bulk, geneList_sc)
# 匹配共同基因, bulk 数据和单细胞数据中的索引
ia <- match(geneList, geneList_bulk)
ib <- match(geneList, geneList_sc)
# 筛选数据矩???
data_matrix_bulk <- data_matrix_bulk[ia, ]
data_matrix_sc <- data_matrix_sc[ib, ]
data_matrix_sc <- log2(data_matrix_sc + 1)
setwd("D:/projects/17-grape/tobacco/TL0")
scS_cluster <- paste0('scS_', Integrated$seurat_clusters)
cluster <- scS_cluster
geneList_sc <- rownames(SS_sc)
rownames(SS_sc) <- geneList_sc
Integrated1 <- CreateSeuratObject(counts = SS_sc, project = "Integrated", min.cells = 0, min.features = 0)
Integrated1 <- NormalizeData(Integrated1, verbose = FALSE)
Integrated1 <- FindVariableFeatures(Integrated1, selection.method = "vst", nfeatures = 2000)
expression_var = SS_sc[Integrated1@assays$RNA@var.features,]
#raw <- avereps(raw,ID=rownames(raw))
#expression <- as.matrix(raw)
gene_feature <- rownames(expression_var)
gene_feature <- data.frame(gene_feature)
rownames(gene_feature) <- rownames(expression_var)
colnames(gene_feature) <- "gene_short_name"
gene_feature <- data.frame(gene_feature)
group <- data.frame(cluster=cluster)
rownames(group) <- colnames(expression_var)
colnames(group) <- c("cluster")
pd <- new("AnnotatedDataFrame", data = group)
fd <- new("AnnotatedDataFrame", data = gene_feature)
cds <- newCellDataSet(expression_var, phenoData = pd, featureData = fd)
cds<- estimateSizeFactors(cds)
cds_reduced <- reduceDimension(cds,norm_method ='none')#), max_components = 2, num_dim = 6, reduction_method = 'DDRTree', verbose = T
cds_for_pseudo <- orderCells(cds_reduced)
# 读取 RDS 文件
data <- readRDS("D:/projects/17-grape/tobacco/TL0/scSTAR2_sc.rds")
# 处理 SS_sc 矩阵
SS_sc <- data$SS_sc
SS_sc <- matrix(as.numeric(SS_sc), nrow = nrow(SS_sc), dimnames = dimnames(SS_sc))
genelist <- unlist(data$geneList_OGFSC_share)
rownames(SS_sc) <- genelist
colnames(SS_sc) <- colnames(data_matrix_sc)
# 处理 data_matrix_sc 矩阵
data_matrix_sc <- data$data_matrix_sc
data_matrix_sc <- matrix(as.numeric(data_matrix_sc), nrow = nrow(data_matrix_sc), dimnames = dimnames(data_matrix_sc))
rownames(data_matrix_sc) <- genelist
colnames(data_matrix_sc) <- paste0("Cell", 1:ncol(data_matrix_sc))
# 处理 S_sc 矩阵
S_sc <- data$S_sc
S_sc <- matrix(as.numeric(S_sc), nrow = nrow(S_sc), dimnames = dimnames(S_sc))
rownames(S_sc) <- genelist
#colnames(S_sc) <- paste0("Cell", 1:ncol(S_sc))
#################### scatter scSTAR2
#  Seurat
Integrated <- CreateSeuratObject(counts = SS_sc, project = "Integrated", min.cells = 0, min.features = 0)
Integrated <- NormalizeData(Integrated, verbose = FALSE)
Integrated <- FindVariableFeatures(Integrated, selection.method = "vst", nfeatures = 2000)
Integrated <- ScaleData(Integrated, verbose = FALSE)
Integrated <- RunPCA(Integrated, npcs = 20, verbose = FALSE)
Integrated <- RunTSNE(Integrated, dims = 1:20)
Integrated <- FindNeighbors(Integrated, reduction = "pca", dims = 1:20)
Integrated <- FindClusters(Integrated, resolution = 0.3)
n <- length(unique(Integrated$seurat_clusters)) - 1
scS_cluster <- paste0('scS_', Integrated$seurat_clusters)
library(Seurat)
library(pls)
library(MASS)
library(ggplot2)
library(readxl)
library(tcltk)
library(STutility)
library(wrMisc)
library(scSTAR2)
library(circlize)
library(monocle)
library(dplyr)
mesophyll_cells_TL0 <- readRDS("./mesophyll_cells_TL0.rds")
setwd("D:/projects/17-grape/tobacco/all")
mesophyll_cells_all <- readRDS("./mesophyll_cells_all.rds")
mesophyll_cells_TL0 <- mesophyll_cells_all[, mesophyll_cells_all$orig.ident == "tl0"]
setwd("D:/projects/17-grape/tobacco/TL0")
saveRDS(mesophyll_cells_TL0, "./mesophyll_cells_TL0.rds")
# Visualization
library(ggplot2)
library(dplyr)
library(tibble)
umap_df <- mesophyll_cells@reductions$tsne@cell.embeddings %>% as.data.frame()
# 2. 提取细胞类型信息，这里假设是 seurat_clusters，或你可以替换成实际变量名
meta_df <- mesophyll_cells@meta.data
# 3. 合并数据，按细胞名
plot_df <- merge(umap_df, meta_df[, "seurat_clusters", drop=FALSE], by = "row.names")
plot_df <- plot_df %>% column_to_rownames("Row.names")
# 4. 格式化细胞类型（可选）
plot_df$seurat_clusters <- paste0("ori", plot_df$seurat_clusters)
# 5. 定义颜色（根据你细胞类型数目调整）
cluster_colors <- c("#fb9e9a","#d688a1","#a7789f","#e0845d","#0075c3","#47c4f1","#008eb9","#c06967","#798945","#51040f")
# 6. ggplot绘制
ggplot(plot_df, aes(x = tSNE_1, y = tSNE_2, fill = seurat_clusters, colour = seurat_clusters)) +
geom_point(shape = 21, size = 1.5, alpha = 0.15) +
scale_fill_manual(values = cluster_colors) +
scale_colour_manual(values = cluster_colors) +
theme_bw(base_rect_size = 1) +
theme(
axis.title = element_text(size = 15),
axis.text = element_text(size = 12),
panel.grid = element_blank(),
legend.title = element_blank(),
legend.text = element_text(size = 12),
legend.position = "right",
legend.key.height = unit(1, "cm"),
legend.key.width = unit(0.5, "cm"),
plot.title = element_text(size = 16, face = "bold", hjust = 0.5)
) +
ggtitle("Mesophyll_TL0 Cluster") +
guides(fill = guide_legend(override.aes = list(size = 3, alpha = 0.8)))
