geom_point(aes(size = number_of_out)) +
scale_size_continuous(range = c(2, 6)) +
scale_color_manual(values = mycolor) +
scale_y_discrete(expand = expansion(mult = c(0.05, 0.05)))+
labs(x = "", y = " ", color = "Cluster", size = "Gene count",
title = " ") +
mytheme1
# 保存
ggsave("D:/projects/17-grape/tobacco/TL0/7.GO_Bubble.tiff",
plot = p, width = 8, height = 6.5, dpi = 300, compression = "lzw")
