library(corrplot)
library(pheatmap)
# 1. 读取所有RDS文件
mesophyll <- readRDS("D:/projects/17-grape/tobacco/all/mesophyll_cells_all.rds")
bs <- readRDS("D:/projects/17-grape/tobacco/all/bs/bs_cells_all.rds")
companion <- readRDS("D:/projects/17-grape/tobacco/all/companion/companion_cells_all.rds")
epidermic <- readRDS("D:/projects/17-grape/tobacco/all/epidermic/epidermic_cells_all.rds")
guard <- readRDS("D:/projects/17-grape/tobacco/all/guard/guard_cells_all.rds")
meristem <- readRDS("D:/projects/17-grape/tobacco/all/meristem/meristem_cells_all.rds")
pp <- readRDS("D:/projects/17-grape/tobacco/all/pp/pp_cells_all.rds")
primordium <- readRDS("D:/projects/17-grape/tobacco/all/primordium/primordium_cells_all.rds")
trichome <- readRDS("D:/projects/17-grape/tobacco/all/trichome/trichome_cells_all.rds")
xylem <- readRDS("D:/projects/17-grape/tobacco/all/xylem/xylem_cells_all.rds")
# 2. 为每个数据集添加来源标识和唯一细胞类型名称
add_dataset_label <- function(seurat_obj, dataset_name) {
seurat_obj$dataset <- dataset_name
# 使用细胞类型标签或默认标识
if ("cellTypeLabel" %in% colnames(seurat_obj@meta.data)) {
seurat_obj$cellType_combined <- paste0(dataset_name, "_", seurat_obj@meta.data$cellTypeLabel)
} else if ("seurat_clusters" %in% colnames(seurat_obj@meta.data)) {
seurat_obj$cellType_combined <- paste0(dataset_name, "_Cluster", seurat_obj@meta.data$seurat_clusters)
} else {
# 如果没有明确的细胞类型标签，使用数据集名称
seurat_obj$cellType_combined <- dataset_name
}
return(seurat_obj)
}
# 应用标签函数
mesophyll <- add_dataset_label(mesophyll, "Mesophyll")
bs <- add_dataset_label(bs, "BS")
companion <- add_dataset_label(companion, "Companion")
epidermic <- add_dataset_label(epidermic, "Epidermic")
guard <- add_dataset_label(guard, "Guard")
meristem <- add_dataset_label(meristem, "Meristem")
pp <- add_dataset_label(pp, "PP")
primordium <- add_dataset_label(primordium, "Primordium")
trichome <- add_dataset_label(trichome, "Trichome")
xylem <- add_dataset_label(xylem, "Xylem")
# 3. 合并所有Seurat对象
seurat_list <- list(
mesophyll, bs, companion, epidermic, guard,
meristem, pp, primordium, trichome, xylem
)
# 合并Seurat对象
combined_seurat <- merge(seurat_list[[1]], y = seurat_list[-1])
# 4. 设置统一的细胞类型标识
Idents(combined_seurat) <- combined_seurat$cellType_combined
# 首先检查所有可用的细胞类型
cat("所有可用的细胞类型:\n")
all_cell_types <- levels(Idents(combined_seurat))
print(all_cell_types)
cat("总细胞类型数:", length(all_cell_types), "\n")
# 5. 调试：检查我们想要选择的细胞类型是否真的存在
selected_clusters <- c(
"Mesophyll_Cluster0", "Mesophyll_Cluster1", "Mesophyll_Cluster2",
"Mesophyll_Cluster3", "Mesophyll_Cluster4", "Mesophyll_Cluster6",
"Mesophyll_Cluster7", "Mesophyll_Cluster8", "Mesophyll_Cluster9",
"BS_Cluster0",
"Epidermic_Cluster5",
"Meristem_Cluster0"
)
# 检查哪些细胞类型存在
existing_clusters <- intersect(selected_clusters, all_cell_types)
# 创建子集
subset_seurat <- subset(combined_seurat, idents = existing_clusters)
# 6. 简化细胞类型名称（只对存在的细胞类型）
# 首先创建完整的映射
full_simple_names <- c(
"Mesophyll_Cluster0" = "Meso0",
"Mesophyll_Cluster1" = "Meso1",
"Mesophyll_Cluster2" = "Meso2",
"Mesophyll_Cluster3" = "Meso3",
"Mesophyll_Cluster4" = "Meso4",
"Mesophyll_Cluster6" = "Meso6",
"Mesophyll_Cluster7" = "Meso7",
"Mesophyll_Cluster8" = "Meso8",
"Mesophyll_Cluster9" = "Meso9",
"Primordium_Cluster4" = "Prim4",
"Primordium_Cluster5" = "Prim5",
"PP_Cluster2" = "PP2",
"PP_Cluster3" = "PP3",
"Xylem_Cluster0" = "Xyl0",
"Trichome_Cluster3" = "Trich3",
"BS_Cluster0" = "BS0",
"BS_Cluster1" = "BS1",
"Epidermic_Cluster5" = "Epi5",
"Guard_Cluster2" = "Guard2",
"Guard_Cluster4" = "Guard4",
"Meristem_Cluster0" = "Meristem0"
)
# 只保留实际存在的映射
simple_names <- full_simple_names[names(full_simple_names) %in% existing_clusters]
# 更新细胞类型标识
current_idents <- as.character(Idents(subset_seurat))
new_idents <- simple_names[current_idents]
# 处理没有映射的细胞类型（保持原名）
new_idents[is.na(new_idents)] <- current_idents[is.na(new_idents)]
Idents(subset_seurat) <- new_idents
# 查看选择的细胞类型
cat("最终选择的细胞类型:\n")
final_celltypes <- table(Idents(subset_seurat))
print(final_celltypes)
cat("开始Monocle2轨迹分析...\n")
# 使用 subset_seurat 的表达矩阵
expr_mat <- subset_seurat@assays$RNA@counts
clusters <- Idents(subset_seurat)
set.seed(123)
gene_sample <- sample(rownames(expr_mat), 1500)
expr_mat <- expr_mat[gene_sample, ]
# 构建 fd / pd
gene_ann <- data.frame(gene_short_name = rownames(expr_mat))
rownames(gene_ann) <- rownames(expr_mat)
fd <- new("AnnotatedDataFrame", data = gene_ann)
pd <- data.frame(
cluster = clusters,
cellType_combined = subset_seurat$cellType_combined
)
rownames(pd) <- colnames(expr_mat)
pd <- new("AnnotatedDataFrame", data = pd)
# 创建 CDS
cds <- newCellDataSet(expr_mat,
phenoData = pd,
featureData = fd,
expressionFamily = negbinomial.size())
cds <- estimateSizeFactors(cds)
cds <- reduceDimension(cds, reduction_method = "DDRTree")
cds <- orderCells(cds)  # 不手动指定root，先让它自动选
plot_cell_trajectory(cds, color_by = "cellType_combined") +
theme(legend.position = "right") +
ggtitle("Monocle2 Trajectory by Cell Type")
plot_cell_trajectory(cds, color_by = "Pseudotime") +
scale_color_gradientn(colors = rainbow(5)) +
ggtitle("Monocle2 Trajectory by Pseudotime")
rm(list = ls())
gc()
graphics.off()
