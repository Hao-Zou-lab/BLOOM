library(monocle)
library(Seurat)
# 1. 使用 Seurat 对象的表达矩阵
expr_mat <- subset_seurat@assays$RNA@counts
# 2. 现有 cluster
clu <- Idents(subset_seurat)
# 3. 创建新的 mes_group，并保留其他所有 cluster 不变
subset_seurat$mes_group <- as.character(clu)
subset_seurat$mes_group[clu %in% c(1,2,3,7,8,9)] <- "mes_qf"
subset_seurat$mes_group[clu %in% c(0,4,6)] <- "mes_cz"
subset_seurat$mes_group <- factor(subset_seurat$mes_group)
table(subset_seurat$mes_group)
unique(as.character(clu))
clu <- Idents(subset_seurat)
# 3. 创建新的 mes_group，并保留其他所有 cluster 不变
subset_seurat$mes_group <- as.character(clu)
subset_seurat$mes_group[clu %in% c("Meso1","Meso2","Meso3","Meso7","Meso8","Meso9")] <- "mes_qf"
subset_seurat$mes_group[clu %in% c("Meso0","Meso4","Meso6")] <- "mes_cz"
subset_seurat$mes_group <- factor(subset_seurat$mes_group)
table(subset_seurat$mes_group)
# 4. 随机抽取 1500 基因，加速 Monocle2
set.seed(123)
gene_sample <- sample(rownames(expr_mat), 1500)
expr_mat <- expr_mat[gene_sample, ]
# 5. 构建 featureData (基因注释表)
gene_ann <- data.frame(gene_short_name = rownames(expr_mat))
rownames(gene_ann) <- rownames(expr_mat)
fd <- new("AnnotatedDataFrame", data = gene_ann)
# 6. 构建 phenotypeData (细胞注释)
pd <- data.frame(
cluster = clu,
mes_group = subset_seurat$mes_group
)
rownames(pd) <- colnames(expr_mat)
pd <- new("AnnotatedDataFrame", data = pd)
# 7. 创建 CDS 对象
cds <- newCellDataSet(expr_mat,
phenoData = pd,
featureData = fd,
expressionFamily = negbinomial.size())
cds <- estimateSizeFactors(cds)
cds <- reduceDimension(cds, reduction_method = "DDRTree")
cds <- orderCells(cds)  # 不手动指定root，先让它自动选
plot_cell_trajectory(cds, color_by = "cellType_combined") +
theme(legend.position = "right") +
ggtitle("Monocle2 Trajectory by Cell Type")
plot_cell_trajectory(cds, color_by = "mes_group") +
theme(legend.position = "right") +
ggtitle("Monocle2 Trajectory by Cell Type")
plot_cell_trajectory(cds, color_by = "Pseudotime") +
scale_color_gradientn(colors = rainbow(5)) +
ggtitle("Monocle2 Trajectory by Pseudotime")
library(ggridges)
library(ggplot2)
# 构建数据框：伪时间 + 分组信息
pseudotime_df <- data.frame(
pseudotime = pData(cds)$Pseudotime,
mes_group = pData(cds)$mes_group
)
# 去掉 NA（Monocle 轨迹外的细胞可能会 NA）
pseudotime_df <- pseudotime_df[!is.na(pseudotime_df$pseudotime), ]
# 保存图
ggplot(pseudotime_df, aes(x = pseudotime, y = mes_group, fill = mes_group)) +
geom_density_ridges(scale = 2, alpha = 0.85) +
theme_classic() +
theme(
text = element_text(size = 16, face = "bold"),
axis.title = element_text(size = 18, face = "bold"),
legend.position = "none"
) +
xlab("Pseudotime") +
ylab("Cell Type Group") +
ggtitle("Pseudotime Distribution Across Cell Types (Ridge Plot)")
plot_cell_trajectory(cds, color_by = "State")
plot_cell_trajectory(cds, color_by = "mes_group")
unique(cds$mes_group)
# 假设你只想看 mes_group == "mes_qf"
cds_subset <- cds[, pData(cds)$mes_group == "BS0"]
plot_cell_trajectory(cds_subset, color_by = "mes_group") +
theme(legend.position = "right") +
ggtitle("Monocle2 Trajectory: BS0")
p <- plot_cell_trajectory(cds, color_by = "mes_group")
# 只显示 mes_group == "mes_qf"
p_subset <- p +
scale_color_manual(values = c("mes_qf" = "red")) +  # 自定义颜色
guides(color = guide_legend(override.aes = list(alpha = 1))) +
theme(legend.position = "right") +
ggtitle("Monocle2 Trajectory: mes_qf")
p_subset
p <- plot_cell_trajectory(cds, color_by = "mes_group")
# 只显示 mes_group == "BS0"
p_subset <- p +
scale_color_manual(values = c("BS0" = "red")) +  # 自定义颜色
guides(color = guide_legend(override.aes = list(alpha = 1))) +
theme(legend.position = "right") +
ggtitle("Monocle2 Trajectory: BS0")
p_subset
